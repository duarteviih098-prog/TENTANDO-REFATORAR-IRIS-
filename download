{% extends 'base.html' %}
{% block content %}
<section class="hero dash-hero clean-shell">
  <div>
    <div class="mini text-uppercase fw-bold mb-2 soft-kicker">Painel operacional</div>
    <h1>Início</h1>
    <p>Bombas, entregas e pagamentos numa leitura rápida, clara e mais elegante.</p>
  </div>
  <div class="hero-chip-wrap">
    <a class="hero-chip soft-chip dash-link-card" href="{{ url_for('os_page', status='andamento') }}">
      <span>O.S. em andamento</span>
      <strong>{{ dashboard_data.cards.os_em_andamento }}</strong>
    </a>
    <a class="hero-chip soft-chip dash-link-card" href="{{ url_for('os_page', status='pausadas') }}">
      <span>O.S. pausadas</span>
      <strong>{{ dashboard_data.cards.os_pausadas }}</strong>
    </a>
  </div>
</section>

<section class="dash-cards clean-shell compact-cards">
  <article class="dash-card card-blue">
    <div class="label">Bombas em estoque</div>
    <div class="value">{{ dashboard_data.cards.bombas_estoque }}</div>
    <div class="hint">prontas para uso</div>
  </article>
  <article class="dash-card card-green">
    <div class="label">Bombas em conserto</div>
    <div class="value">{{ dashboard_data.cards.bombas_conserto }}</div>
    <div class="hint">na oficina ou ajuste</div>
  </article>
  <article class="dash-card card-amber payment-card">
    <div class="label">Total gasto no mês</div>
    <div class="value money">{{ dashboard_data.cards.valor_pendente|br_money }}</div>
    <div class="hint">somando todos os lançamentos do mês atual</div>
  </article>
  <a class="dash-card card-red dash-link-card" href="{{ url_for('os_page', status='atrasadas') }}">
    <div class="label">O.S. em atraso</div>
    <div class="value">{{ dashboard_data.cards.os_atrasadas }}</div>
    <div class="hint">clique para ver na aba de O.S.</div>
  </a>
  <a class="dash-card card-purple dash-link-card" href="{{ url_for('os_page', componentes='Sim') }}">
    <div class="label">Troca de componentes</div>
    <div class="value">{{ dashboard_data.cards.componentes_total }}</div>
    <div class="hint">{{ dashboard_data.cards.componentes_percentual }}% das O.S. com troca</div>
  </a>
</section>

<section class="dash-grid clean-grid">
  <div class="chart-card wide clean-shell">
    <div class="chart-head">
      <div>
        <h3>Ritmo financeiro</h3>
        <span>valor lançado por mês</span>
      </div>
      <div class="chart-pill">Financeiro</div>
    </div>
    <canvas id="financeTrendChart"></canvas>
  </div>

  <div class="chart-card clean-shell compact-card">
    <div class="chart-head">
      <div>
        <h3>Entrega das bombas</h3>
        <span>andamento, entregue ou atraso</span>
      </div>
      <div class="chart-pill">Entrega</div>
    </div>
    <canvas id="osStatusChart"></canvas>
  </div>

  <div class="chart-card clean-shell compact-card">
    <div class="chart-head">
      <div>
        <h3>Bombas por situação</h3>
        <span>estoque x conserto</span>
      </div>
      <div class="chart-pill">Bombas</div>
    </div>
    <canvas id="bombasLocalChart"></canvas>
  </div>

  <div class="chart-card clean-shell compact-card">
    <div class="chart-head">
      <div>
        <h3>Status dos pagamentos</h3>
        <span>pendentes x realizados</span>
      </div>
      <div class="chart-pill">Status</div>
    </div>
    <canvas id="pagamentosChart"></canvas>
  </div>

  <div class="chart-card clean-shell compact-card">
    <div class="chart-head">
      <div>
        <h3>O.S. por sistema</h3>
        <span>onde a demanda mais aperta</span>
      </div>
      <div class="chart-pill">Operação</div>
    </div>
    <canvas id="osSistemaChart"></canvas>
  </div>

  <div class="chart-card clean-shell compact-card">
    <div class="chart-head">
      <div>
        <h3>O.S. em atraso por sistema</h3>
        <span>onde a fila já passou do ponto</span>
      </div>
      <div class="chart-pill">Sistema</div>
    </div>
    <canvas id="osAtrasadasChart"></canvas>
  </div>

  <div class="chart-card clean-shell compact-card">
    <div class="chart-head">
      <div>
        <h3>Sistemas com troca de componentes</h3>
        <span>onde houve troca registrada</span>
      </div>
      <div class="chart-pill">Componentes</div>
    </div>
    <canvas id="componentesSistemaChart"></canvas>
  </div>

  <div class="chart-card clean-shell compact-card">
    <div class="chart-head">
      <div>
        <h3>Componentes mais trocados</h3>
        <span>ranking pelo texto informado na O.S.</span>
      </div>
      <div class="chart-pill">Manutenção</div>
    </div>
    <canvas id="componentesTipoChart"></canvas>
  </div>

  <div class="chart-card clean-shell compact-card">
    <div class="chart-head">
      <div>
        <h3>Equipamentos problemáticos</h3>
        <span>prioridade por O.S., atraso, pausa e troca</span>
      </div>
      <div class="chart-pill">Inteligência</div>
    </div>
    <canvas id="equipamentosCriticosChart"></canvas>
  </div>

  <div class="alerts-card clean-shell maintenance-alerts">
    <div class="chart-head">
      <div>
        <h3>Alertas de manutenção</h3>
        <span>o que merece atenção primeiro</span>
      </div>
      <div class="chart-pill">Radar</div>
    </div>
    <div class="alerts-list">
      {% for alert in dashboard_data.alerts %}
      <a class="alert-row {{ alert.level }} dash-link-card" href="{{ url_for('os_page') }}">
        <div><span>⚙️</span><small>{{ alert.title }}</small></div>
        <strong>{{ alert.value }}</strong>
      </a>
      {% endfor %}
    </div>
  </div>
</section>
{% endblock %}

{% block scripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
const chartHolders = [];
let chartBuildQueued = false;

function themeTokens(){
  const root = getComputedStyle(document.documentElement);
  return {
    font: root.getPropertyValue('--text').trim() || '#24324a',
    muted: root.getPropertyValue('--muted').trim() || '#70819b',
    grid: root.getPropertyValue('--chart-grid').trim() || 'rgba(148, 163, 184, 0.18)',
    gridSoft: root.getPropertyValue('--chart-grid-soft').trim() || 'rgba(148, 163, 184, 0.10)',
    tooltipBg: root.getPropertyValue('--chart-tooltip-bg').trim() || 'rgba(255,255,255,0.98)',
    tooltipTitle: root.getPropertyValue('--chart-tooltip-title').trim() || '#142033',
    tooltipBody: root.getPropertyValue('--chart-tooltip-body').trim() || '#36485f',
    chartBorder: root.getPropertyValue('--chart-border').trim() || '#f8fbff'
  };
}

function applyChartDefaults(tokens){
  Chart.defaults.color = tokens.font;
  Chart.defaults.font.family = 'Inter, Segoe UI, Arial, sans-serif';
  Chart.defaults.plugins.legend.labels.usePointStyle = true;
  Chart.defaults.plugins.legend.labels.boxWidth = 10;
}

function buildGradient(ctx, colors){
  const g = ctx.createLinearGradient(0, 0, 0, 260);
  colors.forEach(([stop, color]) => g.addColorStop(stop, color));
  return g;
}

function baseOptions(tokens, extra={}){
  return {
    responsive: true,
    maintainAspectRatio: false,
    animation: false,
    interaction: { mode: 'index', intersect: false },
    plugins: {
      legend: {
        labels: { color: tokens.font, padding: 18, font: { weight: '600' } }
      },
      tooltip: {
        backgroundColor: tokens.tooltipBg,
        borderColor: tokens.grid,
        borderWidth: 1,
        titleColor: tokens.tooltipTitle,
        bodyColor: tokens.tooltipBody,
        padding: 12,
        cornerRadius: 14,
        displayColors: true,
      }
    },
    scales: {
      x: {
        ticks: { color: tokens.muted },
        grid: { color: tokens.grid, drawBorder: false }
      },
      y: {
        ticks: { color: tokens.muted },
        grid: { color: tokens.grid, drawBorder: false }
      }
    },
    ...extra
  };
}


function goTo(url){
  window.location.href = url;
}

function urlWith(base, params){
  const u = new URL(base, window.location.origin);
  Object.entries(params || {}).forEach(([k,v]) => {
    if(v !== undefined && v !== null && String(v).trim() !== '') u.searchParams.set(k, v);
  });
  return u.pathname + u.search;
}

function makePointClick(chartRef, callback){
  return (evt, elements) => {
    const hit = elements && elements.length ? elements[0] : null;
    if(!hit) return;
    const label = chartRef.data.labels[hit.index];
    const value = chartRef.data.datasets?.[hit.datasetIndex || 0]?.data?.[hit.index];
    callback(label, value, hit);
  };
}

function clickableOptions(opts){
  opts = opts || {};
  opts.onHover = (event, elements) => {
    const target = event?.native?.target || event?.target;
    if(target) target.style.cursor = elements && elements.length ? 'pointer' : 'default';
  };
  return opts;
}

function createCharts(){
  chartBuildQueued = false;
  chartHolders.splice(0).forEach(ch => ch.destroy());
  const t = themeTokens();
  applyChartDefaults(t);

  const financeCtx = document.getElementById('financeTrendChart').getContext('2d');
  const financeGradient = buildGradient(financeCtx, [[0, 'rgba(59, 130, 246, 0.24)'], [1, 'rgba(59, 130, 246, 0.02)']]);
  const financeChart = new Chart(financeCtx, {
    type: 'line',
    data: {
      labels: {{ dashboard_data.pagamentos_mes_labels|tojson }},
      datasets: [{
        label: 'Valor',
        data: {{ dashboard_data.pagamentos_mes_values|tojson }},
        borderColor: '#2563eb',
        backgroundColor: financeGradient,
        fill: true,
        tension: .35,
        pointRadius: 4,
        pointHoverRadius: 6,
        pointBackgroundColor: '#60a5fa',
        pointBorderWidth: 0,
        borderWidth: 3
      }]
    },
    options: clickableOptions(baseOptions(t, {
      plugins: { legend: { display: false }, tooltip: baseOptions(t).plugins.tooltip },
      scales: {
        x: { ticks: { color: t.muted }, grid: { color: t.gridSoft } },
        y: { ticks: { color: t.muted }, grid: { color: t.grid } }
      }
    }))
  });
  financeChart.options.onClick = makePointClick(financeChart, (mes) => goTo(urlWith('/pagamentos', { mes })));
  chartHolders.push(financeChart);

  const statusCtx = document.getElementById('osStatusChart').getContext('2d');
  const statusChart = new Chart(statusCtx, {
    type: 'doughnut',
    data: {
      labels: {{ dashboard_data.os_status_labels|tojson }},
      datasets: [{
        data: {{ dashboard_data.os_status_values|tojson }},
        backgroundColor: ['#60a5fa', '#34d399', '#f87171'],
        borderColor: t.chartBorder,
        borderWidth: 4,
        hoverOffset: 8
      }]
    },
    options: clickableOptions({
      responsive: true,
      maintainAspectRatio: false,
      cutout: '68%',
      animation: false,
      plugins: {
        legend: { position: 'bottom', labels: { color: t.font, padding: 16 } },
        tooltip: baseOptions(t).plugins.tooltip
      }
    })
  });
  statusChart.options.onClick = makePointClick(statusChart, (label) => {
    const q = String(label || '').toLowerCase().includes('atras') ? 'em atraso' : label;
    goTo(urlWith('/controle', { q }));
  });
  chartHolders.push(statusChart);

  const bombasCtx = document.getElementById('bombasLocalChart').getContext('2d');
  const bombasChart = new Chart(bombasCtx, {
    type: 'bar',
    data: {
      labels: {{ dashboard_data.bombas_local_labels|tojson }},
      datasets: [{
        label: 'Bombas',
        data: {{ dashboard_data.bombas_local_values|tojson }},
        backgroundColor: ['rgba(37, 99, 235, 0.82)', 'rgba(16, 185, 129, 0.82)'],
        borderRadius: 16,
        borderSkipped: false,
        maxBarThickness: 54
      }]
    },
    options: clickableOptions(baseOptions(t, { plugins: { legend: { display: false }, tooltip: baseOptions(t).plugins.tooltip } }))
  });
  bombasChart.options.onClick = makePointClick(bombasChart, (label) => {
    const loc = String(label || '').toLowerCase().includes('conserto') ? 'conserto' : 'estoque';
    goTo(urlWith('/controle', { localizacao: loc }));
  });
  chartHolders.push(bombasChart);

  const pagamentoCtx = document.getElementById('pagamentosChart').getContext('2d');
  const pagamentosChart = new Chart(pagamentoCtx, {
    type: 'bar',
    data: {
      labels: {{ dashboard_data.pagamentos_labels|tojson }},
      datasets: [{
        label: 'Quantidade',
        data: {{ dashboard_data.pagamentos_values|tojson }},
        backgroundColor: ['rgba(245, 158, 11, 0.82)', 'rgba(59, 130, 246, 0.82)'],
        borderRadius: 16,
        borderSkipped: false,
        maxBarThickness: 58
      }]
    },
    options: clickableOptions(baseOptions(t, { plugins: { legend: { display: false }, tooltip: baseOptions(t).plugins.tooltip } }))
  });
  pagamentosChart.options.onClick = makePointClick(pagamentosChart, (label) => {
    const status = String(label || '').toLowerCase().includes('pago') && !String(label || '').toLowerCase().includes('não') ? 'Sim' : 'Não';
    goTo(urlWith('/pagamentos', { status }));
  });
  chartHolders.push(pagamentosChart);

  const sistemaCtx = document.getElementById('osSistemaChart').getContext('2d');
  const sistemaChart = new Chart(sistemaCtx, {
    type: 'bar',
    data: {
      labels: {{ dashboard_data.os_sistema_labels|tojson }},
      datasets: [{
        label: 'O.S.',
        data: {{ dashboard_data.os_sistema_values|tojson }},
        backgroundColor: 'rgba(99, 102, 241, 0.82)',
        borderRadius: 16,
        borderSkipped: false
      }]
    },
    options: clickableOptions(baseOptions(t, {
      indexAxis: 'y',
      plugins: { legend: { display: false }, tooltip: baseOptions(t).plugins.tooltip }
    }))
  });
  sistemaChart.options.onClick = makePointClick(sistemaChart, (label) => goTo(urlWith('/os', { q: label })));
  chartHolders.push(sistemaChart);


  const atrasadasCtx = document.getElementById('osAtrasadasChart').getContext('2d');
  const atrasadasChart = new Chart(atrasadasCtx, {
    type: 'bar',
    data: {
      labels: {{ dashboard_data.os_atrasadas_labels|tojson }},
      datasets: [{
        label: 'O.S. atrasadas',
        data: {{ dashboard_data.os_atrasadas_values|tojson }},
        backgroundColor: 'rgba(239, 68, 68, 0.82)',
        borderRadius: 16,
        borderSkipped: false
      }]
    },
    options: clickableOptions(baseOptions(t, {
      indexAxis: 'y',
      plugins: { legend: { display: false }, tooltip: baseOptions(t).plugins.tooltip }
    }))
  });
  atrasadasChart.options.onClick = makePointClick(atrasadasChart, (label) => goTo(urlWith('/os', { status: 'atrasadas', q: label })));
  chartHolders.push(atrasadasChart);

  const componentesEl = document.getElementById('componentesSistemaChart');
  if(componentesEl){
    const compCtx = componentesEl.getContext('2d');
    const componentesChart = new Chart(compCtx, {
      type: 'bar',
      data: {
        labels: {{ dashboard_data.componentes_sistema_labels|tojson }},
        datasets: [{
          label: 'Trocas',
          data: {{ dashboard_data.componentes_sistema_values|tojson }},
          backgroundColor: 'rgba(16, 185, 129, 0.82)',
          borderRadius: 16,
          borderSkipped: false
        }]
      },
      options: clickableOptions(baseOptions(t, {
        indexAxis: 'y',
        plugins: { legend: { display: false }, tooltip: baseOptions(t).plugins.tooltip }
      }))
    });
    componentesChart.options.onClick = makePointClick(componentesChart, (label) => {
      if(String(label || '').toLowerCase().includes('sem')) return;
      goTo(urlWith('/os', { componentes: 'Sim', q: label }));
    });
    chartHolders.push(componentesChart);
  }

  const compTipoEl = document.getElementById("componentesTipoChart");
  if(compTipoEl){
    const compTipoChart = new Chart(compTipoEl.getContext("2d"), {
      type: "bar",
      data: { labels: {{ dashboard_data.componentes_tipo_labels|tojson }}, datasets: [{ label: "Trocas", data: {{ dashboard_data.componentes_tipo_values|tojson }}, backgroundColor: "rgba(14, 165, 233, 0.82)", borderRadius: 16, borderSkipped: false }] },
      options: clickableOptions(baseOptions(t, { indexAxis: "y", plugins: { legend: { display: false }, tooltip: baseOptions(t).plugins.tooltip } }))
    });
    compTipoChart.options.onClick = makePointClick(compTipoChart, (label) => { if(!String(label || "").toLowerCase().includes("sem")) goTo(urlWith("/os", { componentes: "Sim", q: label })); });
    chartHolders.push(compTipoChart);
  }

  const equipCritEl = document.getElementById("equipamentosCriticosChart");
  if(equipCritEl){
    const equipCritChart = new Chart(equipCritEl.getContext("2d"), {
      type: "bar",
      data: { labels: {{ dashboard_data.equipamentos_criticos_labels|tojson }}, datasets: [{ label: "Prioridade", data: {{ dashboard_data.equipamentos_criticos_values|tojson }}, backgroundColor: "rgba(244, 63, 94, 0.82)", borderRadius: 16, borderSkipped: false }] },
      options: clickableOptions(baseOptions(t, { indexAxis: "y", plugins: { legend: { display: false }, tooltip: baseOptions(t).plugins.tooltip } }))
    });
    equipCritChart.options.onClick = makePointClick(equipCritChart, (label) => { if(!String(label || "").toLowerCase().includes("sem")) goTo(urlWith("/os", { q: label })); });
    chartHolders.push(equipCritChart);
  }
}

function queueCharts(){
  if(chartBuildQueued) return;
  chartBuildQueued = true;
  const runner = () => createCharts();
  if ('requestIdleCallback' in window) {
    requestIdleCallback(runner, { timeout: 400 });
  } else {
    setTimeout(runner, 60);
  }
}
queueCharts();
window.addEventListener('gg-theme-change', queueCharts);
</script>
<style>
.clean-shell{position:relative}
.dash-link-card{text-decoration:none;color:inherit;transition:transform .16s ease, box-shadow .16s ease}
.dash-link-card:hover{transform:translateY(-2px);color:inherit;box-shadow:0 18px 36px rgba(15,23,42,.12)}
.dash-hero{display:flex;justify-content:space-between;align-items:center;gap:20px;padding:22px 26px 24px;margin-bottom:18px}
.soft-kicker{letter-spacing:.18em;color:#2563eb}
.hero-chip-wrap{display:flex;gap:12px;flex-wrap:wrap;justify-content:flex-end}
.hero-chip{min-width:160px;padding:14px 16px;border-radius:18px;background:var(--chart-surface);border:1px solid color-mix(in srgb,var(--line) 70%, transparent);box-shadow:0 12px 28px rgba(15,23,42,.08)}
.hero-chip span{display:block;font-size:.76rem;text-transform:uppercase;letter-spacing:.12em;color:var(--muted);margin-bottom:4px}
.hero-chip strong{font-size:1.15rem;color:var(--chart-strong)}
.soft-chip{box-shadow:0 12px 28px rgba(15,23,42,.08)}
.compact-cards{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;margin-bottom:18px}
.dash-card{background:var(--chart-surface);border:1px solid color-mix(in srgb,var(--line) 70%, transparent);box-shadow:0 16px 30px rgba(15,23,42,.07);border-radius:20px;padding:18px;min-height:126px;display:flex;flex-direction:column;justify-content:space-between}
.dash-card .label{font-weight:700;color:var(--muted);font-size:.92rem}
.dash-card .value{font-size:1.95rem;font-weight:800;color:var(--chart-strong);line-height:1.06;letter-spacing:-.02em}
.dash-card .hint{font-size:.86rem;color:var(--muted)}
.card-blue .value{color:#2563eb}
.card-green .value{color:#059669}
.card-amber .value{color:#d97706}
.card-red .value{color:#dc2626}
.card-purple .value{color:#7c3aed}
.clean-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
.chart-card,.alerts-card{background:var(--chart-surface);border:1px solid color-mix(in srgb,var(--line) 70%, transparent);box-shadow:0 16px 34px rgba(15,23,42,.07);border-radius:22px;padding:18px;min-height:330px;position:relative;overflow:hidden}
.chart-card.wide{grid-column:span 2;min-height:360px}
.chart-card canvas{width:100%!important;height:265px!important;cursor:pointer}
.chart-card.wide canvas{height:290px!important}
.chart-head{display:flex;justify-content:space-between;align-items:flex-start;gap:10px;margin-bottom:14px;position:relative;z-index:1}
.chart-head h3{margin:0;font-size:1.06rem;font-weight:800;color:var(--chart-strong)}
.chart-head span{font-size:.85rem;color:var(--muted)}
.chart-pill{padding:8px 12px;border-radius:999px;background:rgba(37,99,235,.08);border:1px solid rgba(37,99,235,.14);font-size:.74rem;letter-spacing:.08em;text-transform:uppercase;color:#2563eb}
.alerts-list{display:grid;gap:12px;margin-top:4px;position:relative;z-index:1}
.alert-row{display:flex;justify-content:space-between;align-items:center;border-radius:16px;padding:14px 16px;background:var(--chart-surface-soft);border:1px solid color-mix(in srgb,var(--line) 65%, transparent);gap:12px}
.alert-row div{display:flex;align-items:center;gap:8px;color:var(--text)}
.alert-row small{color:var(--muted)}
.alert-row strong{font-size:1rem}
.alert-row.warning strong{color:#d97706}.alert-row.danger strong{color:#dc2626}.alert-row.ok strong{color:#059669}.alert-row.info strong{color:#2563eb}
.compact-card{min-height:330px}
.maintenance-alerts{min-height:330px}
.alert-row{text-decoration:none;color:inherit}
.alert-row:hover{color:inherit}
@media (max-width:1400px){.compact-cards{grid-template-columns:repeat(2,1fr)}.clean-grid{grid-template-columns:1fr 1fr}.chart-card.wide{grid-column:span 2}}
@media (max-width:980px){.dash-hero{flex-direction:column;align-items:flex-start}.hero-chip-wrap{justify-content:flex-start}.clean-grid,.compact-cards{grid-template-columns:1fr}.chart-card.wide{grid-column:span 1}}
</style>
{% endblock %}

<style>html[data-theme="dark"] .soft-kicker{color:#8fc1ff} html[data-theme="dark"] .chart-pill{background:rgba(76,156,240,.12);border-color:rgba(76,156,240,.24);color:#a8ceff}</style>
