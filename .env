# Copie para .env e preencha os valores (nunca commite .env)

# Flask
SECRET_KEY=
# IRIS_PRODUCTION=1
# FLASK_ENV=production
APP_TIMEZONE=America/Sao_Paulo
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=1
SESSION_COOKIE_SECURE=0
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_NAME=iris_session
SESSION_DAYS=7
SESSION_IDLE_MINUTES=120
MAX_UPLOAD_MB=20

# Banco de dados (Postgres/Supabase em produção; omitir para SQLite local app.db)
DATABASE_URL=
# SUPABASE_DB_HOST=
# SUPABASE_DB_PORT=5432
# SUPABASE_DB_NAME=postgres
# SUPABASE_DB_USER=
# SUPABASE_DB_PASSWORD=
# DB_POOL_MAXCONN=4

# Supabase Storage
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_KEY=
# SUPABASE_ANON_KEY=
SUPABASE_STORAGE_BUCKET=uploads
PAYMENT_STORAGE_FOLDER=BOLETO E NF
OS_STORAGE_FOLDER=os

# URL pública (Render/produção)
# PUBLIC_BASE_URL=
# RENDER_EXTERNAL_URL=
# APP_URL=

# Outlook / Microsoft Graph
# OUTLOOK_TENANT_ID=
# OUTLOOK_CLIENT_ID=
# OUTLOOK_CLIENT_SECRET=

# SMTP (e-mail transacional / recuperação de senha)
