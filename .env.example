# Copie para .env e preencha (nunca commite .env)

# Flask
SECRET_KEY=
IRIS_PRODUCTION=0
APP_TIMEZONE=America/Sao_Paulo
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=1

# Banco (Postgres/Supabase em produção; omitir para SQLite local app.db)
DATABASE_URL=

# Supabase Storage (obrigatório em produção com anexos)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=uploads
PAYMENT_STORAGE_FOLDER=BOLETO E NF
OS_STORAGE_FOLDER=os

# Observabilidade
# SENTRY_DSN=
# IRIS_JSON_LOGS=1

# SMTP (reset de senha)
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# Outlook / monitor
# OUTLOOK_TENANT_ID=
# OUTLOOK_CLIENT_ID=
# OUTLOOK_CLIENT_SECRET=
# MONITOR_IMAP_HOST=outlook.office365.com
# MONITOR_IMAP_USER=
# MONITOR_IMAP_PASS=
# ENABLE_MONITOR_WORKER=0

