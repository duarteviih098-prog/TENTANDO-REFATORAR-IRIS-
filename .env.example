# Copie para .env e preencha os valores (nunca commite .env)

# Flask
SECRET_KEY=
# IRIS_PRODUCTION=1
APP_TIMEZONE=America/Sao_Paulo
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=1

# Banco (Postgres/Supabase em produção; omitir para SQLite local app.db)
DATABASE_URL=

# Supabase Storage
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=uploads

# Observabilidade (opcional)
# SENTRY_DSN=
# IRIS_JSON_LOGS=1

# SMTP (reset de senha)
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
